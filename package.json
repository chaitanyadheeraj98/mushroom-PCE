{
  "name": "mushroom-pce",
  "displayName": "mushroom-PCE",
  "description": "AI Prompt Constraint Engine for structured and controlled code generation inside VS Code.",
  "version": "0.5.0",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:mushroom-pce.start",
    "onCommand:mushroom-pce.analyzeActive",
    "onCommand:mushroom-pce.selectModel",
    "onCommand:mushroom-pce.goToFunction",
    "onCommand:mushroom-pce.setListMode",
    "onCommand:mushroom-pce.setDeveloperMode",
    "onCommand:mushroom-pce.openCircuit",
    "onCommand:mushroom-pce.openBlueprint"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "mushroom-pce.start",
        "title": "Start Mushroom PCE"
      },
      {
        "command": "mushroom-pce.analyzeActive",
        "title": "Mushroom PCE: Analyze Active File"
      },
      {
        "command": "mushroom-pce.selectModel",
        "title": "Mushroom PCE: Select Model"
      },
      {
        "command": "mushroom-pce.goToFunction",
        "title": "Mushroom PCE: Go To Function"
      },
      {
        "command": "mushroom-pce.setListMode",
        "title": "Mushroom PCE: Set List Mode"
      },
      {
        "command": "mushroom-pce.setDeveloperMode",
        "title": "Mushroom PCE: Set Developer Mode"
      },
      {
        "command": "mushroom-pce.openCircuit",
        "title": "Mushroom PCE: Open Circuit Mode"
      },
      {
        "command": "mushroom-pce.openBlueprint",
        "title": "Mushroom PCE: Open Blueprint"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "dependencies": {
    "three": "^0.163.0"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.17",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}

